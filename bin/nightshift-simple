#!/usr/bin/env bash

set -Eeuo pipefail

# Simple nightshift runner with GitHub integration
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT_DIR"

# Parse command line arguments
PRIORITY="github"  # Default: prioritize GitHub issues

while [[ $# -gt 0 ]]; do
  case $1 in
    --priority=*)
      PRIORITY="${1#*=}"
      shift
      ;;
    --priority)
      PRIORITY="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [--priority=github|docs]"
      exit 1
      ;;
  esac
done

# Validate priority value
if [[ "$PRIORITY" != "github" ]] && [[ "$PRIORITY" != "docs" ]]; then
  echo "Invalid priority: $PRIORITY"
  echo "Valid options: github, docs"
  exit 1
fi

START_TIME=$(date +%s)
MAX_DURATION=$((8 * 60 * 60))  # 8 hours in seconds
PASS=1
SESSION_ID="$(date +%Y%m%d-%H%M%S)"
STATE_DIR="$ROOT_DIR/.git/nightshift/$SESSION_ID"
REVIEW_FILE="$STATE_DIR/nightshift-review.md"

mkdir -p "$STATE_DIR"

# GitHub helper functions
check_gh_available() {
  command -v gh >/dev/null 2>&1
}

fetch_github_issues() {
  if ! check_gh_available; then
    echo "[]"
    return
  fi

  gh project item-list 4 --owner "@me" --format json 2>/dev/null | \
    jq -r '.items[] | select(.status == "Todo") | .content.number' 2>/dev/null || echo ""
}

close_github_issue() {
  local issue_number="$1"
  local commit_message="$2"

  if ! check_gh_available; then
    return
  fi

  echo "  → Closing GitHub issue #$issue_number"
  gh issue close "$issue_number" \
    --comment "✅ Completed by nightshift

Commit: $commit_message

Session: $SESSION_ID" 2>/dev/null || echo "  → Failed to close issue #$issue_number"
}

# Initialize review file
cat > "$REVIEW_FILE" <<EOF
# Nightshift Review — $SESSION_ID

Started: $(date)
Repository: $(basename "$ROOT_DIR")

## Summary

This file tracks what nightshift accomplished during this session.

## Completed Work

EOF

echo "Nightshift session: $SESSION_ID"
echo "Review file: $REVIEW_FILE"
echo "Starting nightshift at $(date)"
echo "Will run for up to 8 hours"
echo "Task priority: $PRIORITY"
echo

# Fetch GitHub issues at start
if check_gh_available; then
  GITHUB_ISSUES=$(fetch_github_issues)
  ISSUE_COUNT=$(echo "$GITHUB_ISSUES" | wc -w | tr -d ' ')
  if [[ $ISSUE_COUNT -gt 0 ]]; then
    echo "Found $ISSUE_COUNT Todo issues in GitHub Project #4"
    echo "$GITHUB_ISSUES" | tr ' ' '\n' | while read -r issue; do
      [[ -n "$issue" ]] && echo "  - Issue #$issue"
    done
    echo
  fi
else
  echo "GitHub CLI not available - skipping issue integration"
  echo
fi

while true; do
  ELAPSED=$(($(date +%s) - START_TIME))

  if [[ $ELAPSED -ge $MAX_DURATION ]]; then
    echo "Reached 8-hour limit at $(date)"
    break
  fi

  echo "=== Pass $PASS at $(date) (elapsed: $((ELAPSED / 60)) minutes) ==="

  # Check if working directory is clean
  if [[ -n "$(git status --porcelain)" ]]; then
    echo "Working directory dirty, skipping this pass"
    sleep 60
    PASS=$((PASS + 1))
    continue
  fi

  # Get latest commit before running Claude
  BEFORE_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

  # Build prompt based on priority
  if [[ "$PRIORITY" == "github" ]]; then
    PROMPT="Use /design-md-tasks to find and work on ONE task from GitHub Project #4 or the docs.

When choosing what to work on:
1. **Prioritize GitHub Project #4** for 'Todo' issues: https://github.com/users/MicahDitto/projects/4
2. Check FEATURES.md for items marked 📋 Planned (if no GitHub issues available)
3. Focus on GitHub issues first - they're externally tracked and often represent bugs or user requests

When you commit your work:
- If working on a GitHub issue, include 'Fixes #123' or 'Closes #123' in the commit message
- Use a clear commit message describing what you accomplished
- Commit when done, even if partially complete"
  else
    PROMPT="Use /design-md-tasks to find and work on ONE task from FEATURES.md or other documentation.

When choosing what to work on:
1. **Prioritize FEATURES.md** items marked 📋 Planned
2. Check other documentation (UI_REQUIREMENTS.md, etc.) for planned features
3. Check GitHub Project #4 for 'Todo' issues (if no doc tasks available): https://github.com/users/MicahDitto/projects/4
4. Focus on documentation-driven feature development

When you commit your work:
- If working on a GitHub issue, include 'Fixes #123' or 'Closes #123' in the commit message
- Use a clear commit message describing what you accomplished
- Commit when done, even if partially complete"
  fi

  # Run one task (no timeout - let it run as long as needed)
  claude -p --dangerously-skip-permissions "$PROMPT" || echo "Claude failed"

  # Check if new commit was made
  AFTER_COMMIT=$(git rev-parse HEAD 2>/dev/null || echo "")

  if [[ -n "$AFTER_COMMIT" ]] && [[ "$BEFORE_COMMIT" != "$AFTER_COMMIT" ]]; then
    # Get commit message
    COMMIT_MSG=$(git log -1 --pretty=%B)
    COMMIT_SHORT=$(git log -1 --pretty=%h)

    echo "  ✓ New commit: $COMMIT_SHORT"

    # Log to review file
    echo "### Pass $PASS - $(date +%H:%M)" >> "$REVIEW_FILE"
    echo "" >> "$REVIEW_FILE"
    echo "**Commit:** \`$COMMIT_SHORT\`" >> "$REVIEW_FILE"
    echo "" >> "$REVIEW_FILE"
    echo '```' >> "$REVIEW_FILE"
    echo "$COMMIT_MSG" >> "$REVIEW_FILE"
    echo '```' >> "$REVIEW_FILE"
    echo "" >> "$REVIEW_FILE"

    # Check for issue references and try to close them
    if check_gh_available; then
      ISSUE_NUMS=$(echo "$COMMIT_MSG" | grep -oE '#[0-9]+' | sed 's/#//' || echo "")
      for issue in $ISSUE_NUMS; do
        close_github_issue "$issue" "$COMMIT_MSG"
        echo "- Closed issue #$issue" >> "$REVIEW_FILE"
      done
    fi

    echo "---" >> "$REVIEW_FILE"
    echo "" >> "$REVIEW_FILE"
  else
    echo "  ℹ No commit made this pass"
  fi

  PASS=$((PASS + 1))
  sleep 60  # Wait 1 min between tasks
done

echo
echo "Nightshift complete at $(date)"
TOTAL_ELAPSED=$(($(date +%s) - START_TIME))
echo "Total runtime: $((TOTAL_ELAPSED / 60)) minutes"
echo

# Finalize review file
cat >> "$REVIEW_FILE" <<EOF

## Session Summary

- **Total passes:** $((PASS - 1))
- **Duration:** $((TOTAL_ELAPSED / 60)) minutes
- **Completed:** $(date)

## Next Steps

1. Review the commits made during this session:
   \`\`\`bash
   git log --oneline --since="$(date -r $START_TIME '+%Y-%m-%d %H:%M:%S')"
   \`\`\`

2. Check if any GitHub issues were closed

3. Update FEATURES.md status markers for completed work

4. Run \`bin/sync-docs-github\` to verify consistency

---

**Review File Location:** \`$REVIEW_FILE\`
EOF

echo "───────────────────────────────────────"
echo "Review file created: $REVIEW_FILE"
echo "───────────────────────────────────────"
echo
echo "Quick review:"
echo "  cat $REVIEW_FILE"
echo
echo "Check commits since session start:"
echo "  git log --oneline --since='$(date -r $START_TIME '+%Y-%m-%d %H:%M:%S')'"
